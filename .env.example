# Copy this file to .env and fill in your Gmail App Password.
# Never commit .env to source control.

# Gmail App Password (NOT your regular Gmail password)
# How to get one:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search "App Passwords" in the search bar
#   4. Create one, name it "Baseball Digest"
#   5. Paste the 16-character password below (spaces are fine, or omit them)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
