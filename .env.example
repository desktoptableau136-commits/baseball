# Copy this file to .env and fill in your credentials.
# Never commit .env to source control.

# Gmail App Password (NOT your regular Gmail password)
# How to get one:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search "App Passwords" in the search bar
#   4. Create one, name it "Baseball Digest"
#   5. Paste the 16-character password below (spaces are fine, or omit them)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ESPN session cookies (required by fetch_data.py — there are no hardcoded fallbacks)
# How to capture them:
#   1. Log in to fantasy.espn.com in Chrome
#   2. F12 -> Application tab -> Cookies -> https://fantasy.espn.com
#   3. Copy the SWID value (keep the curly braces) and the espn_s2 value (long string)
# These are session cookies: if fetch_data starts failing with auth errors, re-capture
# them here AND update the ESPN_SWID / ESPN_S2 GitHub Actions secrets.
ESPN_SWID={XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX}
ESPN_S2=paste_the_long_espn_s2_cookie_value_here
